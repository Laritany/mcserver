	order_index: 12
	quest_links: [ ]
	quests: [
		{
			description: [
				"原版向日葵已经被一种新的向日葵取代，"
				"新的向日葵现在会随着太阳旋转，还可以从中收获葵花籽。"
				""
				"葵花籽可以烤熟，能像干海带一样快速食用；"
				""
				"仓鼠可以生成为 4 种不同的变种，它们会随机地用后脚站起来以侦察危险；"
				""
				"仓鼠可以用葵花籽驯服，驯服后可以让它们坐下或跟随，就像其他宠物一样；"
				""
				"仓鼠的领地意识很强，被同一个玩家驯服的仓鼠会试图杀死对方；"
				""
				"仓鼠会主动捡起物品并将其塞进颊囊中，颊囊的空间塞满时，仓鼠的两颊在外观上也会变大；"
				""
				"玩家可以拿着物品右键打开驯服的仓鼠的颊囊，可以将其作为便携式存储空间。"
			]
			icon: "spawn:hamster_spawn_egg"
			id: "659207FFFA08F57C"
			subtitle: "仓鼠可以在平原和草甸上被找到，更常见于向日葵平原"
			tasks: [{
				id: "1CDE2CCC2A229151"
				observe_type: 5
				timer: 0L
				to_observe: "spawn:hamster"
				type: "observation"
			}]
			title: "仓鼠"
			x: 11.0d
			y: -7.5d
		}
		{
			description: [
				"鸭子可以用种子繁殖。"
				""
				"它们会生产鸭蛋和鸭毛，就像鸡一样。"
				""
				"但与鸡不同的是，鸭子喜欢在水中游泳，把头浸入水中。"
				""
				"如果在它们附近播放唱片机，它们会像鹦鹉一样跳舞！"
				""
				"你可以制作一个空鸭袋，并像把鱼装进桶里一样用它来运输鸭子。"
			]
			icon: "untitledduckmod:duck_spawn_egg"
			id: "1E74C4F4562C8478"
			tasks: [{
				id: "24663C6694DC6713"
				observe_type: 5
				timer: 0L
				to_observe: "untitledduckmod:duck"
				type: "observation"
			}]
			title: "鸭"
			x: 4.5d
			y: -10.5d
		}
		{
			description: [
				"你可以用种子像鸭一样繁殖鹅。"
				""
				"它们喜欢海带和海草。你可以用这些吸引、驯服它们！"
				""
				"鹅类似于驯服的狼，它们会和你一起攻击，并保护你免受怪物的攻击。"
				""
				"鹅一旦驯服了，你可以让它坐下，并给它武器，就像驯服的狼一样。"
				""
				"一旦遭受攻击，鹅会记住并且成群结队地攻击敌人。"
				""
				"可以通过点击使用键或按投掷键扔给它们食物，当你给它们的食物的时候，它会原谅你对它们的攻击行为。"
				""
				"它会吓跑灾厄村民，就像猫吓跑苦力怕一样。"
				""
				"它们会尝试偷你手中的物品，但很罕见，当它们这么做时，它们会交还给你食物。"
				""
				"掉落物："
				""
				"生鹅肉（若被火烧死则掉落熟鹅肉）；"
				""
				"鹅脚；"
				""
				"鹅每5-10分钟会下一次鹅蛋；即使鹅处于濒死状态，它仍然有可能下蛋。"
			]
			icon: "untitledduckmod:goose_spawn_egg"
			id: "24E881216B745929"
			tasks: [{
				id: "6AF67784BCDA7BA0"
				observe_type: 5
				timer: 0L
				to_observe: "untitledduckmod:goose"
				type: "observation"
			}]
			title: "鹅"
			x: 4.5d
			y: -12.0d
		}
		{
			description: [""]
			icon: "wildernature:deer_spawn_egg"
			id: "629EDEEB90F33A6C"
			subtitle: "鹿不能被驯服，但它们可以用草来繁殖"
			tasks: [{
				id: "2EDC8F8755B73B8B"
				observe_type: 5
