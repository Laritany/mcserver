			title: "狗"
			x: 5.0d
			y: -7.5d
		}
		{
			description: [
				"死亡会掉落很多羽毛。"
				""
				"虽然它们不能被驯服，但它们可以使用鱼进行繁殖"
			]
			icon: "wildernature:flamingo_spawn_egg"
			id: "054C9C107EFD9617"
