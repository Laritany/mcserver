				type: "observation"
			}]
			title: "鹿"
			x: 0.5d
			y: -6.0d
		}
		{
			description: [
				"松鼠不能被永久驯服。"
				"要暂时驯服它活繁殖它们，请使用榛子。"
			]
			icon: "wildernature:squirrel_spawn_egg"
			id: "19096CDBFD331237"
			subtitle: "哦，好可爱！他们喜欢吃榛子、偷树苗和四处奔跑。"
			tasks: [{
				id: "4628F201914F3AA5"
				observe_type: 5
				timer: 0L
				to_observe: "wildernature:squirrel"
				type: "observation"
			}]
			title: "松鼠"
			x: 9.5d
			y: -12.0d
		}
		{
			description: [""]
			icon: "wildernature:red_wolf_spawn_egg"
			id: "0480BFDC08B06EB8"
			subtitle: "红狼与狼相同 可用骨头驯服"
			tasks: [{
				id: "5EC57EE24E02EE3D"
				observe_type: 5
				timer: 0L
				to_observe: "wildernature:red_wolf"
				type: "observation"
			}]
			title: "红狼"
			x: 11.0d
			y: -6.0d
		}
		{
			description: [
				"你以前就那样杀死这些手无寸铁的生物吗？"
				"现在它们可以寻找它们的动物朋友寻求帮助。"
				""
				"死亡后，会掉落羽毛和鹈鹕肉。"
				""
				"虽然它们不能被驯服，但它们可以使用鱼进行繁殖。"
			]
			icon: "wildernature:pelican_spawn_egg"
			id: "61DB7768765ED96C"
			subtitle: "啊，我记得沙滩派对的这些东西！可以在沙滩中找到"
			tasks: [{
				id: "6453253BF0739587"
				observe_type: 5
				timer: 0L
				to_observe: "wildernature:pelican"
				type: "observation"
			}]
			title: "鹈鹕"
			x: 0.5d
			y: -10.5d
		}
		{
			description: [
				"企鹅喜欢船，尤其是你的船。"
				"如果他们看到附近有船，他们就会跳上船并起飞。"
				"然而，它们的驾驶技术并不是最好的。"
				"他们还做什么？它们将他们所在的船的速度提高10%"
			]
			icon: "wildernature:penguin_spawn_egg"
			id: "30D514FA995690A0"
			subtitle: "一个真正的海盗。为什么？稍后会详细介绍。出现在冰雪生物群系中。"
			tasks: [{
				id: "5E9F3BF0561CABAD"
				observe_type: 5
				timer: 0L
				to_observe: "wildernature:penguin"
				type: "observation"
			}]
			title: "企鹅"
			x: 7.0d
			y: -7.5d
		}
		{
			description: [
				"他们喜欢偷偷溜进村庄四处游荡。浣熊可以开门。"
				"死亡后，他们有几率掉落一个装有食物或其他物品的战利品袋。"
				""
				""
				"浣熊不能被驯服，但可以使用以下物品之一进行繁殖："
				"苹果、胡萝卜、甜菜、土豆、熟鲑鱼、熟鳕鱼"
			]
			icon: "wildernature:raccoon_spawn_egg"
			id: "74EB3BA3EC06BF04"
			subtitle: "浣熊几乎无处不在。"
			tasks: [{
				id: "59A2FACD16A37533"
				observe_type: 5
				timer: 0L
				to_observe: "wildernature:raccoon"
				type: "observation"
			}]
			title: "浣熊"
			x: 9.5d
			y: -10.5d
		}
		{
			description: [
				"狗是中立的，不会打扰或骚扰任何人。"
				"如果他们看到一只猫，一场疯狂的追逐就开始了！"
				""
				"死亡后，狗会掉落骨头。"
				""
				"狗与狼具有相同的战利品表和繁殖特性。"
				""
				"使用骨头驯服"
			]
			icon: "wildernature:dog_spawn_egg"
			id: "455B786894AB0886"
			subtitle: "这是狗吗？是的！狗可以在村庄或平原生物群系中找到"
