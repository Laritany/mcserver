			y: -6.0d
		}
		{
			description: [
				"请不要给它喂牛奶。"
				""
				"他掉落什么？你为什么要杀他？它什么都不掉。"
				""
				"刺猬不能被驯服，只能用腐肉繁殖。"
			]
			icon: "wildernature:hedgehog_spawn_egg"
			id: "45A1ACBE524986D5"
